{% import 'partial/responsive-image.twig' as responsive %}

{% macro render_term(term) %}
    <a href="{{ term.link }}"
       class="w-[calc((100%_-_1rem)/3)] min-w-35 flex-none snap-start overflow-hidden rounded-sm bg-gray-800 sm:w-[calc((100%_-_1.5rem)/4)]">
        <div class="relative aspect-[9/16]">
            {% set image = get_image(term.meta('dossier_afbeelding_hoog')) %}
            {{ responsive.render(
                src: image.src,
                width: 226,
                height: 402,
                sizes: '(min-width: 960px) 226px, (min-width: 640px) calc((100vw - 3.5rem) / 4), calc((100vw - 3rem) / 3)',
                alt: image.alt|default(term.title),
                class: 'absolute inset-0 w-full',
            ) }}
            <i class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black opacity-60"></i>
            <h2 class="absolute inset-x-0 bottom-0 p-4 text-center text-md font-black text-white sm:text-xl">{{ term.title }}</h2>
        </div>
    </a>
{% endmacro %}

<section class="py-4 dark:border-t dark:border-gray-700/50" data-scroller>
    <div class="mx-auto flex max-w-960 items-center px-4 pb-4">
        <h2 class="text-3xl font-bold dark:text-white">Dossiers</h2>
        <div class="ml-auto flex gap-1.5" data-scroller-nav hidden>
            <button type="button" data-scroller-prev disabled aria-label="Vorige dossiers"
                    class="flex h-8 w-8 items-center justify-center rounded-sm bg-gray-100 text-gray-800 transition hover:bg-gray-200 disabled:cursor-default disabled:opacity-40 dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600">{{ icon('icon-arrow_back') }}</button>
            <button type="button" data-scroller-next aria-label="Volgende dossiers"
                    class="flex h-8 w-8 items-center justify-center rounded-sm bg-gray-100 text-gray-800 transition hover:bg-gray-200 disabled:cursor-default disabled:opacity-40 dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600">{{ icon('icon-arrow_forward') }}</button>
        </div>
    </div>
    <div class="mx-auto flex max-w-960 snap-x snap-proximity gap-2 overflow-x-auto px-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
         data-scroller-track>
        {% for term in block.terms %}
            {{ _self.render_term(term) }}
        {% endfor %}
    </div>
</section>
