{# This file demonstrates using most of the index.twig template and modifying
   just a small part. See `search.twig` for an example of another approach #}

{% extends 'archive.twig' %}

{% block content %}
    {% import 'partial/responsive-image.twig' as responsive %}

    <div class="lg:hidden">
        <div class="aspect-[21/9] relative">
            <div>
                {% set wide_image = get_image(term.dossier_afbeelding_breed) %}
                {{ responsive.render(
                    wide_image.src,
                    1024,
                    439,
                    '(max-width: 1023px) 100vw, 1px',
                    wide_image.alt|default(term.name, true),
                    'object-cover absolute inset-0 w-full h-full',
                    'eager',
                ) }}
                <div class="absolute inset-x-0 bottom-0 h-32 max-h-full bg-gradient-to-t from-white dark:from-gray-800"></div>
            </div>

        </div>
    </div>
    <div class="w-full mx-auto max-w-960 py-4 px-4 -mt-16 relative lg:mt-0">
        <div class="lg:grid gap-4 grid-cols-3" style="grid-template-rows: fit-content(50%) 1fr;">
            <div class="lg:col-start-2 lg:col-span-2">
                <h1 class="font-bold dark:text-white">
                    <span class="block text-sm tracking-wide uppercase font-round">Dossier</span>
                    <span class="block text-3xl">{{ term.name }}</span>
                </h1>
            </div>

            <div class="lg:row-start-1 lg:row-span-2">
                <div class="hidden lg:block overflow-hidden bg-gray-800 rounded-sm">
                    <div class="aspect-[9/16] relative">
                        <div>
                            {% set tall_image = get_image(term.meta('dossier_afbeelding_hoog')) %}
                            {{ responsive.render(
                                tall_image.src,
                                299,
                                532,
                                '(min-width: 1024px) 299px, 1px',
                                tall_image.alt|default(term.name, true),
                                'absolute inset-0 w-full',
                            ) }}
                        </div>
                    </div>
                </div>
                <div class="prose dark:prose-invert py-4 w-auto">{{ term.description }}</div>
            </div>

            <div class="lg:col-start-2 lg:col-span-2 grid sm:grid-cols-2 gap-4">
                {% for post in posts %}
                    {{ include('partial/tile-post.twig', {post: post}) }}
                {% endfor %}
            </div>
        </div>

        {{ include('partial/pagination.twig', {pagination: posts.pagination({show_all: false, mid_size: 1, end_size: 1})}) }}
    </div>
{% endblock %}
